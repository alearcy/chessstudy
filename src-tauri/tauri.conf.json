{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chess Study",
  "version": "1.0.0",
  "identifier": "com.chessstudy.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Chess Study",
        "width": 1440,
        "height": 900,
        "minWidth": 1366,
        "minHeight": 800,
        "resizable": true,
        "maximized": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "license": "GPL-3.0",
    "resources": {
      "binaries/stockfish": "binaries/stockfish",
      "binaries/stockfish-x86_64-pc-windows-msvc.exe": "binaries/stockfish-x86_64-pc-windows-msvc.exe"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
